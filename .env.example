# ═══════════════════════════════════════════════════════
# FARAHNA Wedding Planner — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/farahna?retryWrites=true&w=majority

# JWT secret key (generate a random 64+ character string)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Server port (Render sets this automatically)
PORT=3000

# Node environment
NODE_ENV=development
